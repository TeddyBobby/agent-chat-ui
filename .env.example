# Agent Chat UI — Environment Variables
# Copy this file to .env.local and fill in your values

# ---- OpenAI (default) ----
OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- DeepSeek ----
# When model ID starts with "deepseek", these are used instead of OpenAI configs
# DEEPSEEK_API_KEY=sk-xxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ---- Other providers ----
# For Ollama (local): select "gemma4:e4b" model in UI — base URL auto-set
# For any OpenAI-compatible API, use OPENAI_API_KEY + OPENAI_BASE_URL
